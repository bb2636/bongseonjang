{
  "name": "@bongkru/frontend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:capacitor": "vite build --mode capacitor",
    "assets": "npx @capacitor/assets generate --iconBackgroundColor FFFFFF --splashBackgroundColor FFFFFF --ios --android",
    "cap:sync": "npx cap sync && node scripts/fix-ios-native.js",
    "cap:sync:ios": "node scripts/cap-ensure-ios.js && npx cap sync ios && node scripts/fix-ios-native.js",
    "cap:sync:android": "npx cap sync android && node scripts/fix-capacitor-paths.js",
    "cap:build": "npm run assets && vite build --mode capacitor && npm run cap:sync:android",
    "cap:build:ios": "node scripts/cap-build-ios.js full",
    "cap:build:ios:quick": "node scripts/cap-build-ios.js quick",
    "cap:open": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "fix:ios-plist": "node scripts/fix-ios-native.js",
    "fix:ios-native": "node scripts/fix-ios-native.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@bongkru/contract": "*",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "7.4.4",
    "@capacitor/app": "7.0.1",
    "@capacitor/browser": "7.0.1",
    "@capacitor/camera": "7.0.0",
    "@capacitor/cli": "7.4.4",
    "@capacitor/core": "7.4.4",
    "@capacitor/ios": "7.4.4",
    "@capacitor/share": "7.0.0",
    "@capgo/inappbrowser": "^7.29.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.90.12",
    "@uppy/aws-s3": "^5.1.0",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.0",
    "@uppy/react": "^5.1.1",
    "lottie-react": "^2.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.10.1",
    "swiper": "^12.0.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/react": "^18.0.15",
    "@types/react-dom": "^18.0.6",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.0.0",
    "vite": "^7.2.7"
  }
}
